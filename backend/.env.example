DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# Optional. Required for correct rate limiting when running multiple gunicorn/uWSGI workers or
# processes -- without it, the throttle cache falls back to per-process local memory and each
# worker undercounts independently. Not needed for single-process `manage.py runserver`.
# REDIS_URL=redis://localhost:6379/0
# FORMY_SUBMISSION_THROTTLE_RATE=30/hour

